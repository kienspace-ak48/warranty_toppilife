  <a
    href="/warranty/chinh-sach"
    class="relative -mb-px pb-3 text-base font-semibold transition sm:text-lg <%= wsub === 'policy' ? 'text-[#39B54A] after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:rounded-full after:bg-[#39B54A]' : 'text-slate-900 hover:text-[#39B54A]' %>"
