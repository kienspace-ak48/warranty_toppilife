<div class="sidebar sidebar-dark sidebar-fixed border-end" id="sidebar">
    <div class="sidebar-header border-bottom">
      <div class="sidebar-brand">
        <svg class="sidebar-brand-full" width="88" height="32" alt="CoreUI Logo">
          <use xlink:href="/coreui/assets/brand/coreui.svg#full"></use>
        </svg>
        <svg class="sidebar-brand-narrow" width="32" height="32" alt="CoreUI Logo">
          <use xlink:href="/coreui/assets/brand/coreui.svg#signet"></use>
        </svg>
      </div>
      <button class="btn-close d-lg-none" type="button" data-coreui-theme="dark" aria-label="Close" onclick="coreui.Sidebar.getInstance(document.querySelector('#sidebar')).toggle()"></button>
    </div>
    <ul class="sidebar-nav" data-coreui="navigation" data-simplebar>
      <li class="nav-item"><a class="nav-link" href="/admin">
          <svg class="nav-icon">
            <use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-speedometer"></use>
          </svg> Dashboard</a></li>

      <li class="nav-title text-red-500">Sản phẩm</li>
      <li class="nav-item"><a class="nav-link" href="/admin/warranty/product-types">
          <svg class="nav-icon">
            <use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-layers"></use>
          </svg> Loại SP</a></li>
      <li class="nav-item"><a class="nav-link" href="/admin/warranty/products">
          <svg class="nav-icon">
            <use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-devices"></use>
          </svg> SP đăng ký BH</a></li>
      <li class="nav-item"><a class="nav-link" href="/admin/warranty/activation-requests">
          <svg class="nav-icon">
            <use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-list"></use>
          </svg> Duyệt kích hoạt BH</a></li>
      <li class="nav-item"><a class="nav-link" href="/admin/warranty/qr">
          <svg class="nav-icon">
            <use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-qr-code"></use>
          </svg> Tạo mã QR (link tùy chỉnh)</a></li>


      <% if (typeof canAccessSystemAccounts !== 'undefined' && canAccessSystemAccounts) { %>
      <li class="nav-title">Hệ thống</li>
      <li class="nav-group"><a class="nav-link nav-group-toggle" href="#">
        <svg class="nav-icon">
          <use xlink:href="/coreui/vendors/@coreui/icons/svg/free.svg#cil-people"></use>
        </svg> Quản trị</a>
        <ul class="nav-group-items compact">
          <li class="nav-item"><a class="nav-link" href="/admin/system/accounts"><span class="nav-icon"><span class="nav-icon-bullet"></span></span> Tài khoản</a></li>
          <% if (typeof user !== 'undefined' && user && user.role === 'super_admin') { %>
          <li class="nav-item"><a class="nav-link" href="/admin/system/logs/login"><span class="nav-icon"><span class="nav-icon-bullet"></span></span> Đăng nhập</a></li>
          <li class="nav-item"><a class="nav-link" href="/admin/system/logs/audit"><span class="nav-icon"><span class="nav-icon-bullet"></span></span> Audit</a></li>
          <% } %>
        </ul>
      </li>
      <% } %>

    </ul>
    <div class="sidebar-footer border-top d-none d-md-flex">     
      <button class="sidebar-toggler" type="button" data-coreui-toggle="unfoldable"></button>
    </div>
  </div>
