<% var polIframe = typeof policyPageIframeSrc !== 'undefined' && policyPageIframeSrc ? policyPageIframeSrc : 'https://www.toppilife.vn/iframe/bao-hanh'; %>
<% var polIframeAttr = String(polIframe).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;'); %>
<% var polOrigin = typeof policyPageIframeOrigin !== 'undefined' && policyPageIframeOrigin ? policyPageIframeOrigin : ''; %>
<section id="chinh-sach-bao-hanh" class="scroll-mt-24" aria-labelledby="policy-iframe-heading">
  <h2 id="policy-iframe-heading" class="text-2xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-3xl lg:text-4xl">
    CHÍNH SÁCH BẢO HÀNH
  </h2>
  <div class="mt-8 -mx-4 w-[calc(100%+2rem)] sm:-mx-6 sm:w-[calc(100%+3rem)]">
    <div class="overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-sm ring-1 ring-slate-900/5">
      <iframe
        id="policy-warranty-iframe"
        title="Chính sách bảo hành — ToppiLife"
        src="<%= polIframeAttr %>"
        class="block w-full max-w-full border-0 align-top"
        style="min-height: 100vh;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>
</section>
<%# Trang nhúng (cùng origin URL iframe): postMessage({ height: document.documentElement.scrollHeight }) tới parent; có thể lắng nghe { type: 'warranty-embed-parent-ready' } để trả lời. %>
<script>
(function () {
  var iframe = document.getElementById('policy-warranty-iframe');
  if (!iframe) return;
  var allowedOrigin = <%- JSON.stringify(polOrigin) %>;
  var lockedByMessage = false;

  function applyHeight(px) {
    var n = Math.max(480, Math.ceil(px) + 20);
    iframe.style.height = n + 'px';
    iframe.style.minHeight = n + 'px';
  }

  function guessHeight() {
    if (lockedByMessage) return;
    var vh = window.innerHeight;
    var px = Math.round(Math.min(1900, Math.max(920, vh * 1.75)));
    applyHeight(px);
  }

  guessHeight();

  window.addEventListener('resize', function () {
    guessHeight();
  });

  iframe.addEventListener('load', function () {
    guessHeight();
    if (!allowedOrigin || !iframe.contentWindow) return;
    function ping() {
      try {
        iframe.contentWindow.postMessage({ type: 'warranty-embed-parent-ready' }, allowedOrigin);
      } catch (e) {}
    }
    ping();
    setTimeout(ping, 600);
    setTimeout(ping, 2000);
  });

  if (!allowedOrigin) return;

  window.addEventListener('message', function (e) {
    if (e.source !== iframe.contentWindow) return;
    if (e.origin !== allowedOrigin) return;
    var d = e.data;
    var h = null;
    if (typeof d === 'number' && isFinite(d)) h = d;
    else if (d && typeof d === 'object') {
      var v = d.height != null ? d.height : d.frameHeight != null ? d.frameHeight : d.h;
      if (v != null) h = Number(v);
    }
    if (h == null || !isFinite(h) || h < 80) return;
    lockedByMessage = true;
    applyHeight(h);
  });
})();
</script>
