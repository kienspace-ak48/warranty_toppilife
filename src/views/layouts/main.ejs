<!DOCTYPE html>
<html lang="vi" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Warranty ToppiLife' %></title>
    <link rel="icon" href="/favicon.ico">
    <link rel="stylesheet" href="/css/client.css">
</head>
<body class="min-h-full bg-slate-50 text-slate-900 antialiased flex flex-col">
    <header class="border-b border-slate-200/80 bg-white shadow-sm sticky top-0 z-50">
        <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 py-4 sm:px-6">
            <a href="/" class="inline-flex shrink-0 items-center rounded-md outline-none ring-emerald-500/0 transition hover:opacity-90 focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2" aria-label="ToppiLife — về trang chủ">
                <img src="/assets/image/logo.png" alt="ToppiLife" class="h-9 w-auto max-h-10 max-w-[200px] object-contain object-left sm:h-10" width="180" height="40" loading="eager" decoding="async" />
            </a>
            <nav class="flex flex-wrap items-center gap-2 text-sm">
                <a href="/" class="rounded-lg px-3 py-1.5 font-medium text-slate-600 hover:bg-slate-100 hover:text-slate-900">Trang chủ</a>
                <% if (typeof tab === 'undefined') { %>
                    <a href="/warranty/tra-cuu" class="rounded-lg px-3 py-1.5 font-medium text-emerald-700 hover:bg-emerald-50 hover:text-emerald-800">Tra cứu bảo hành</a>
                <% } %>
            </nav>
        </div>
        <% if (typeof tab !== 'undefined') { %>
            <% var wt = tab; %>
            <div class="border-t border-slate-100 bg-slate-50/80">
                <div class="mx-auto flex max-w-6xl flex-wrap gap-1 px-2 py-2 sm:px-4">
                    <a href="/warranty/tra-cuu" class="rounded-lg px-3 py-2 text-sm font-medium transition sm:px-4 <%= wt === 'lookup' ? 'bg-emerald-50 text-emerald-900 ring-1 ring-emerald-200/80' : 'text-slate-600 hover:bg-white hover:text-slate-900' %>">Tra cứu bảo hành</a>
                    <a href="/warranty/kich-hoat" class="rounded-lg px-3 py-2 text-sm font-medium transition sm:px-4 <%= wt === 'activate' ? 'bg-emerald-50 text-emerald-900 ring-1 ring-emerald-200/80' : 'text-slate-600 hover:bg-white hover:text-slate-900' %>">Kích hoạt bảo hành</a>
                    <a href="/warranty/ma-qr" class="rounded-lg px-3 py-2 text-sm font-medium transition sm:px-4 <%= wt === 'qr' ? 'bg-emerald-50 text-emerald-900 ring-1 ring-emerald-200/80' : 'text-slate-600 hover:bg-white hover:text-slate-900' %>">Mã QR</a>
                </div>
            </div>
        <% } %>
    </header>
    <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-6 sm:px-6 sm:py-8">
        <%- body %>
    </main>
    <footer class="border-t border-slate-200 bg-white py-6 text-center text-sm text-slate-500">
        <div class="mx-auto max-w-6xl px-4"><%= typeof tab !== 'undefined' ? 'Bảo hành sản phẩm ToppiLife — tra cứu và kích hoạt' : '© ToppiLife' %></div>
    </footer>
    <div id="warranty-toast-root" class="pointer-events-none fixed right-4 top-20 z-[200] flex max-w-[min(100vw-2rem,22rem)] flex-col gap-2 sm:right-6 sm:top-24" aria-live="polite"></div>
    <script src="/js/warranty-client-forms.js" defer></script>
</body>
</html>
