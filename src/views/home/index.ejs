<div class="space-y-12 sm:space-y-14">
  <%- include('../partials/warranty-product-types-grid', { productTypes: typeof productTypes !== 'undefined' ? productTypes : [], showcaseVariant: 'home' }) %>

  <section class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm ring-1 ring-slate-900/5 sm:p-6" aria-labelledby="home-lookup-heading">
    <h2 id="home-lookup-heading" class="text-lg font-bold tracking-tight text-slate-900 sm:text-xl">Tra cứu nhanh</h2>
    <p class="mt-1 text-sm text-slate-600">Một ô — nhập số điện thoại hoặc serial / mã tem đã đăng ký.</p>
    <form method="get" action="/warranty/tra-cuu" data-warranty-form="lookup" class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-12 sm:items-end">
      <div class="sm:col-span-10" data-warranty-field="q">
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="home_wl_q">Số điện thoại hoặc serial / mã tem</label>
        <input
          type="text"
          name="q"
          id="home_wl_q"
          placeholder="VD: 0859123456 hoặc mã trên tem"
          autocomplete="off"
          class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 font-mono text-sm text-slate-900 shadow-inner shadow-slate-900/5 outline-none transition placeholder:text-slate-400 focus:border-emerald-500 focus:bg-white focus:ring-4 focus:ring-emerald-500/15"
        />
        <p class="mt-1 hidden text-xs text-red-600" data-field-error role="alert"></p>
      </div>
      <div class="sm:col-span-2">
        <button type="submit" class="w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-600/25 transition hover:bg-emerald-700 focus:outline-none focus:ring-4 focus:ring-emerald-500/30 active:scale-[0.98]">
          Tra cứu
        </button>
      </div>
    </form>
  </section>

  <section class="relative overflow-hidden rounded-2xl border border-emerald-100 bg-gradient-to-br from-emerald-600 via-emerald-700 to-teal-800 px-5 py-8 text-white shadow-xl shadow-emerald-900/20 sm:px-8 sm:py-10">
    <div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-white/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-8 left-1/4 h-32 w-64 rounded-full bg-teal-400/20 blur-2xl"></div>
    <div class="relative max-w-2xl">
      <p class="mb-2 inline-flex rounded-full bg-white/15 px-3 py-0.5 text-xs font-semibold uppercase tracking-wider text-emerald-100 ring-1 ring-white/20">ToppiLife</p>
      <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">Bảo hành sản phẩm</h1>
      <p class="mt-3 text-sm leading-relaxed text-emerald-50/95 sm:text-base">
        Tra cứu hạn bảo hành, kích hoạt sau khi mua trên sàn hoặc đại lý, và xem hướng dẫn tìm serial trên tem thiết bị.
      </p>
    </div>
  </section>

  <section aria-labelledby="quick-actions-heading">
    <h2 id="quick-actions-heading" class="mb-4 text-lg font-bold tracking-tight text-slate-900 sm:text-xl">Thao tác nhanh</h2>
    <div class="grid gap-3 sm:grid-cols-3">
      <a
        href="/warranty/tra-cuu"
        class="group flex flex-col rounded-2xl border border-slate-200/90 bg-white p-5 shadow-sm ring-1 ring-slate-900/5 transition hover:border-emerald-300 hover:shadow-md hover:shadow-emerald-900/10"
      >
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700 transition group-hover:bg-emerald-600 group-hover:text-white">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </span>
        <span class="mt-3 font-semibold text-slate-900">Tra cứu bảo hành</span>
        <span class="mt-1 text-sm text-slate-600">Nhập SĐT hoặc serial đã đăng ký.</span>
      </a>
      <a
        href="/warranty/kich-hoat"
        class="group flex flex-col rounded-2xl border border-slate-200/90 bg-white p-5 shadow-sm ring-1 ring-slate-900/5 transition hover:border-emerald-300 hover:shadow-md hover:shadow-emerald-900/10"
      >
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-teal-100 text-teal-800 transition group-hover:bg-teal-600 group-hover:text-white">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </span>
        <span class="mt-3 font-semibold text-slate-900">Kích hoạt bảo hành</span>
        <span class="mt-1 text-sm text-slate-600">Mua qua sàn / đại lý — gửi yêu cầu duyệt.</span>
      </a>
      <a
        href="/warranty/ma-qr"
        class="group flex flex-col rounded-2xl border border-slate-200/90 bg-white p-5 shadow-sm ring-1 ring-slate-900/5 transition hover:border-emerald-300 hover:shadow-md hover:shadow-emerald-900/10"
      >
        <span class="flex h-10 w-10 items-center justify-center rounded-xl bg-slate-100 text-slate-700 transition group-hover:bg-slate-800 group-hover:text-white">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0H9m3-3h3M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </span>
        <span class="mt-3 font-semibold text-slate-900">Mã QR kích hoạt</span>
        <span class="mt-1 text-sm text-slate-600">In mã để khách quét tại quầy.</span>
      </a>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200/80 bg-white p-5 shadow-sm ring-1 ring-slate-900/5 sm:p-6">
    <h2 class="text-lg font-bold tracking-tight text-slate-900 sm:text-xl">Hướng dẫn &amp; lưu ý</h2>
    <ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate-700">
      <li class="flex gap-3">
        <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-xs font-bold text-emerald-800">1</span>
        <span><strong class="text-slate-900">Serial / tem</strong> thường ở mặt sau hoặc cạnh thiết bị — lật ảnh loại sản phẩm ở đầu trang để xem minh họa.</span>
      </li>
      <li class="flex gap-3">
        <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-xs font-bold text-emerald-800">2</span>
        <span><strong class="text-slate-900">Tra cứu</strong> cần đúng serial hoặc số điện thoại đã dùng khi đăng ký bảo hành.</span>
      </li>
      <li class="flex gap-3">
        <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-xs font-bold text-emerald-800">3</span>
        <span><strong class="text-slate-900">Kích hoạt online</strong> dành khi mua ngoài hệ thống cửa hàng: điền mã đơn và thông tin — cửa hàng sẽ duyệt trước khi bảo hành có hiệu lực.</span>
      </li>
    </ul>
  </section>
</div>
