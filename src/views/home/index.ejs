<div class="space-y-14 sm:space-y-20">
  <section class="rounded-2xl border border-slate-200/80 bg-white p-6 shadow-sm ring-1 ring-slate-900/5 sm:p-8 lg:p-10" aria-labelledby="hero-warranty-check">
    <p class="text-sm font-semibold uppercase tracking-wider text-[#39B54A]">ToppiLife</p>
    <h1 id="hero-warranty-check" class="mt-2 text-3xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-4xl lg:text-[2.65rem] lg:leading-[1.15]">
      KIỂM TRA THỜI HẠN BẢO HÀNH ĐIỆN TỬ
    </h1>
    <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-600 sm:text-lg">
      Nhập <strong class="font-semibold text-slate-800">số điện thoại</strong> hoặc <strong class="font-semibold text-slate-800">mã serial / tem</strong> đã đăng ký để xem thời hạn bảo hành và nhật ký hiển thị cho khách hàng.
    </p>
    <form method="get" action="/warranty/tra-cuu" data-warranty-form="lookup" class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-12 sm:items-end">
      <div class="sm:col-span-10" data-warranty-field="q">
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="home_wl_q">Số điện thoại hoặc serial / mã tem</label>
        <input
          type="text"
          name="q"
          id="home_wl_q"
          placeholder="VD: 0859123456 hoặc mã trên tem"
          autocomplete="off"
          class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3.5 font-mono text-base text-slate-900 shadow-inner shadow-slate-900/5 outline-none transition placeholder:text-slate-400 focus:border-[#39B54A] focus:bg-white focus:ring-4 focus:ring-[#39B54A]/15"
        />
        <p class="mt-1 hidden text-xs text-red-600" data-field-error role="alert"></p>
      </div>
      <div class="sm:col-span-2">
        <button type="submit" class="w-full rounded-xl bg-[#39B54A] px-4 py-3.5 text-sm font-semibold text-white shadow-lg shadow-[#39B54A]/30 transition hover:bg-[#2fa043] focus:outline-none focus:ring-4 focus:ring-[#39B54A]/35 active:scale-[0.98]">
          Tra cứu
        </button>
      </div>
    </form>
    <p class="mt-4 text-xs leading-relaxed text-slate-500">
      Serial khớp chính xác; số điện thoại khớp theo dãy số (có thể nhập nhiều định dạng).
    </p>
  </section>

  <section aria-labelledby="serial-guide-heading">
    <h2 id="serial-guide-heading" class="text-2xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-3xl lg:text-4xl">
      HƯỚNG DẪN TÌM SỐ SERIAL CỦA SẢN PHẨM
    </h2>
    <p class="mt-3 max-w-3xl text-base text-slate-600 sm:text-lg">
      Chạm hoặc nhấn vào ảnh từng loại để <strong class="text-slate-800">lật xem mặt sau</strong> — vị trí tem và số serial thường được minh họa rõ ràng.
    </p>
    <div class="mt-8">
      <%- include('../partials/warranty-product-types-grid', { productTypes: typeof productTypes !== 'undefined' ? productTypes : [], showcaseVariant: 'serial-guide' }) %>
    </div>
  </section>

  <%- include('../partials/home-quick-notes') %>
</div>
