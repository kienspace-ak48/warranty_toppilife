<% var fv = typeof formValues !== 'undefined' && formValues ? formValues : {}; %>
<% var mode = typeof mode !== 'undefined' ? mode : 'create'; %>
<% var editingId = typeof editingId !== 'undefined' ? editingId : ''; %>
<% var editingRole = typeof editingRole !== 'undefined' ? editingRole : 'admin'; %>
<div class="container-fluid px-4" style="max-width: 40rem;">
  <h1 class="h4 mb-3"><%= mode === 'create' ? 'Thêm tài khoản admin' : (editingRole === 'super_admin' ? 'Tài khoản super admin' : 'Sửa tài khoản admin') %></h1>

  <% if (typeof formError !== 'undefined' && formError) { %>
    <div class="alert alert-warning py-2 small mb-3" role="alert"><%= formError %></div>
  <% } %>

  <form method="post" action="<%= mode === 'create' ? '/admin/system/accounts' : '/admin/system/accounts/' + editingId %>" class="card border-0 shadow-sm">
    <div class="card-body p-3 p-lg-4">
      <div class="mb-3">
        <label class="form-label small fw-semibold" for="acc_fullName">Họ tên</label>
        <input type="text" class="form-control" id="acc_fullName" name="fullName" required maxlength="120" value="<%= fv.fullName || '' %>" autocomplete="name" />
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold" for="acc_username">Username</label>
        <input type="text" class="form-control" id="acc_username" name="username" required maxlength="40" value="<%= fv.username || '' %>" autocomplete="username" />
        <div class="form-text">Chữ thường, số, dấu chấm, gạch dưới, gạch ngang — 3–40 ký tự.</div>
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold" for="acc_email">Email</label>
        <input type="email" class="form-control" id="acc_email" name="email" required maxlength="120" value="<%= fv.email || '' %>" autocomplete="email" />
      </div>
      <div class="mb-3">
        <label class="form-label small fw-semibold" for="acc_password">Mật khẩu<%= mode === 'edit' ? ' (để trống nếu giữ nguyên)' : '' %></label>
        <input type="password" class="form-control" id="acc_password" name="password" <%= mode === 'create' ? 'required minlength="8"' : 'minlength="8"' %> autocomplete="new-password" />
        <% if (mode === 'create') { %>
          <div class="form-text">Tối thiểu 8 ký tự.</div>
        <% } %>
      </div>
      <div class="mb-3 form-check">
        <input type="checkbox" class="form-check-input" id="acc_status" name="status" value="1" <%= fv.status ? 'checked' : '' %> />
        <label class="form-check-label" for="acc_status">Cho phép đăng nhập</label>
      </div>
      <div class="d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
        <a href="/admin/system/accounts" class="btn btn-outline-secondary btn-sm">Quay lại</a>
      </div>
    </div>
  </form>
</div>
