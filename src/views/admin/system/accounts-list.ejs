<div class="container-fluid px-4">
  <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
    <h1 class="h4 mb-0">Tài khoản đăng nhập</h1>
    <a href="/admin/system/accounts/new" class="btn btn-sm btn-primary">Thêm admin</a>
  </div>

  <% if (typeof flash !== 'undefined' && flash) { %>
    <div class="alert alert-success py-2 small mb-3" role="status"><%= flash %></div>
  <% } %>

  <p class="text-body-secondary small mb-3">
    Một tài khoản <span class="badge text-bg-dark">super_admin</span> toàn quyền (kể cả trang này). Các tài khoản <span class="badge text-bg-secondary">admin</span> quản lý bảo hành, không xóa/sửa super của người khác.
    Gán super lần đầu: cập nhật <code>role: &quot;super_admin&quot;</code> trong MongoDB hoặc đặt biến <code>BOOTSTRAP_SUPER_ADMIN_USERNAME</code> rồi khởi động app (xem log).
  </p>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Họ tên</th>
            <th>Username</th>
            <th>Email</th>
            <th>Vai trò</th>
            <th>Hoạt động</th>
            <th class="text-end" style="min-width: 9rem;">Thao tác</th>
          </tr>
        </thead>
        <tbody>
          <% if (!users || !users.length) { %>
            <tr>
              <td colspan="6" class="text-body-secondary text-center py-4">Chưa có tài khoản admin nào.</td>
            </tr>
          <% } %>
          <% (users || []).forEach(function (row) { %>
            <tr>
              <td class="small"><%= row.fullName %></td>
              <td><code class="small"><%= row.username %></code></td>
              <td class="small"><%= row.email %></td>
              <td>
                <% if (row.role === 'super_admin') { %>
                  <span class="badge text-bg-dark">super_admin</span>
                <% } else { %>
                  <span class="badge text-bg-secondary">admin</span>
                <% } %>
              </td>
              <td class="small">
                <% var st = row.status === true || row.status === 'true' || row.status === 1 || row.status === '1'; %>
                <%= st ? 'Bật' : 'Khóa' %>
              </td>
              <td class="text-end">
                <a href="/admin/system/accounts/<%= row._id %>/edit" class="btn btn-sm btn-outline-primary">Sửa</a>
                <% if (row.role === 'admin') { %>
                  <form method="post" action="/admin/system/accounts/<%= row._id %>/delete" class="d-inline" onsubmit="return confirm('Xóa tài khoản admin này?');">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>
