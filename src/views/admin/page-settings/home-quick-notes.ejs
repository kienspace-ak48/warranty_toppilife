<% var d = typeof data !== 'undefined' && data ? data : { homeQuickNotesTitle: '', homeQuickNotesBodyHtml: '' }; %>
<div class="container-fluid px-3 px-lg-4 py-3 w-100">
  <div class="mb-4">
    <h1 class="h4 mb-1">Lưu ý nhanh — Trang chủ</h1>
    <p class="text-body-secondary small mb-0">Một khối soạn thảo: in đậm, link, danh sách… Hiển thị cuối trang chủ.</p>
  </div>

  <% if (typeof flash !== 'undefined' && flash === 'saved') { %>
    <div class="alert alert-success py-2 small mb-3" role="status">Đã lưu.</div>
  <% } else if (typeof flash !== 'undefined' && flash && flash !== 'saved') { %>
    <div class="alert alert-warning py-2 small mb-3" role="alert"><%= flash %></div>
  <% } %>

  <form method="post" action="/admin/page-settings/home-quick-notes" class="card border-0 shadow-sm w-100" id="form-quick-notes">
    <div class="card-body p-3 p-lg-4">
      <div class="mb-3" style="max-width: 36rem;">
        <label class="form-label small fw-semibold" for="homeQuickNotesTitle">Tiêu đề khối</label>
        <input type="text" class="form-control" id="homeQuickNotesTitle" name="homeQuickNotesTitle" value="<%= d.homeQuickNotesTitle || '' %>" placeholder="Lưu ý nhanh" />
      </div>

      <label class="form-label small fw-semibold" for="homeQuickNotesBodyHtml">Nội dung</label>
      <textarea class="form-control js-tinymce-qnote-single" id="homeQuickNotesBodyHtml" name="homeQuickNotesBodyHtml" rows="16"><%- d.homeQuickNotesBodyHtml || '' %></textarea>

      <div class="mt-3">
        <button type="submit" class="btn btn-primary btn-sm px-4">Lưu</button>
        <a href="/" target="_blank" class="btn btn-outline-secondary btn-sm ms-2">Xem trang chủ</a>
      </div>
    </div>
  </form>
</div>
<script src="/libs/tinymce_8.4.0/js/tinymce/tinymce.min.js"></script>
<script>
(function () {
  var base = '/libs/tinymce_8.4.0/js/tinymce';
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof tinymce === 'undefined') return;
    tinymce.init({
      selector: 'textarea.js-tinymce-qnote-single',
      base_url: base,
      suffix: '.min',
      promotion: false,
      branding: false,
      license_key: 'gpl',
      height: 420,
      min_height: 320,
      menubar: false,
      plugins: 'lists link code',
      toolbar: 'undo redo | blocks | bold italic underline strikethrough | link | bullist numlist | removeformat | code',
      block_formats: 'Paragraph=p; Heading 3=h3',
      content_style: 'body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; font-size: 14px; }',
      setup: function (editor) {
        editor.on('change keyup', function () {
          editor.save();
        });
      },
    });

    var form = document.getElementById('form-quick-notes');
    if (form) {
      form.addEventListener('submit', function () {
        if (typeof tinymce !== 'undefined') tinymce.triggerSave();
      });
    }
  });
})();
</script>
