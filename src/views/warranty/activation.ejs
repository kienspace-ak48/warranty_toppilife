<div class="w-full">
  <div class="mb-6 rounded-2xl border border-[#39B54A]/20 bg-gradient-to-br from-[#39B54A] to-[#2d9440] px-5 py-7 text-white shadow-lg sm:mb-8 sm:px-7 lg:px-8">
    <h1 class="text-xl font-bold tracking-tight sm:text-2xl">Kích hoạt bảo hành</h1>
    <p class="mt-2 max-w-4xl text-sm leading-relaxed text-white/95">
      Lưu ý ở đầu: Dành cho khách mua trên sàn thương mại điện tử(Shopee, Tiktok) hoặc đại lý của ToppiLife: điền thông tin bên dưới. Hệ thống gửi yêu cầu về cửa hàng để xác nhận trước khi bảo hành có hiệu lực.
    </p>
    <p class="mt-2 max-w-4xl text-sm leading-relaxed text-white/95">
      Lưu ý: Vui lòng kích hoạt bảo hành trong vòng 7 ngày kể từ khi nhận hàng. Sau 7 ngày, hệ thống sẽ không xử lý yêu cầu kích hoạt bảo hành.
    </p>
  </div>

  <% if (justSubmitted) { %>
    <div class="mb-6 rounded-2xl border border-[#39B54A]/25 bg-[#39B54A]/10 px-4 py-5 text-slate-900 shadow-sm sm:px-6" role="status">
      <p class="font-semibold">Đã gửi yêu cầu kích hoạt</p>
      <p class="mt-2 text-sm text-slate-800">
        Chúng tôi sẽ xử lý và phản hồi sau khi xác minh thông tin. Bạn có thể dùng mục <a href="/" class="font-medium text-[#39B54A] underline decoration-[#39B54A]/50">Tra cứu bảo hành</a> khi thiết bị đã được duyệt.
      </p>
    </div>
  <% } %>

  <% if (!productTypes || !productTypes.length) { %>
    <p class="rounded-xl border border-dashed border-slate-200 bg-slate-50 px-4 py-6 text-center text-sm text-slate-600">
      Hiện chưa mở kích hoạt online cho loại sản phẩm nào. Vui lòng liên hệ cửa hàng.
    </p>
  <% } else { %>
    <form method="post" action="/warranty/kich-hoat" data-warranty-form="activation" class="rounded-2xl border border-slate-200/90 bg-white p-5 shadow-xl shadow-slate-900/5 ring-1 ring-slate-900/5 sm:p-7 lg:p-8">
      <div class="grid grid-cols-1 gap-5 lg:grid-cols-2 lg:gap-x-8 lg:gap-y-5">
        <div class="lg:col-span-2" data-warranty-field="productTypeId">
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="wa_productTypeId">Tên sản phẩm <span class="text-red-500" aria-hidden="true">*</span></label>
          <select
            name="productTypeId"
            id="wa_productTypeId"
            aria-required="true"
            class="w-full min-h-[44px] rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 text-slate-900 outline-none transition focus:border-[#39B54A] focus:bg-white focus:ring-4 focus:ring-[#39B54A]/15"
          >
            <option value="">— Chọn —</option>
            <% productTypes.forEach(function (pt) { %>
              <option value="<%= pt._id %>" <%= String(formValues.productTypeId || '') === String(pt._id) ? 'selected' : '' %>><%= pt.name %><%= pt.code ? ' (' + pt.code + ')' : '' %></option>
            <% }); %>
          </select>
          <p class="mt-1 hidden text-xs text-red-600" data-field-error role="alert"></p>
        </div>
        <div data-warranty-field="orderCode">
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="wa_orderCode">Mã đơn hàng <span class="text-slate-400 text-sx italic lowercase ">(Mã đơn hàng trên sàn TMĐT / tên cửa hàng đại lý)</span> <span class="text-red-500" aria-hidden="true">*</span></label>
          <input type="text" name="orderCode" id="wa_orderCode" value="<%= formValues.orderCode || '' %>" autocomplete="off" aria-required="true" class="w-full min-h-[44px] rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 outline-none transition focus:border-[#39B54A] focus:bg-white focus:ring-4 focus:ring-[#39B54A]/15" placeholder="VD: mã trên sàn TMĐT" />
          <p class="mt-1 hidden text-xs text-red-600" data-field-error role="alert"></p>
        </div>
        <div data-warranty-field="serialNumber">
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="wa_serial">Số serial / mã tem <span class="text-red-500" aria-hidden="true">*</span></label>
          <input type="text" name="serialNumber" id="wa_serial" value="<%= formValues.serialNumber || '' %>" autocomplete="off" aria-required="true" class="w-full min-h-[44px] rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 font-mono text-sm outline-none transition focus:border-[#39B54A] focus:bg-white focus:ring-4 focus:ring-[#39B54A]/15" placeholder="Trên tem thiết bị" />
          <p class="mt-1 hidden text-xs text-red-600" data-field-error role="alert"></p>
        </div>
        <div data-warranty-field="customerName">
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="wa_name">Họ tên <span class="text-red-500" aria-hidden="true">*</span></label>
          <input type="text" name="customerName" id="wa_name" value="<%= formValues.customerName || '' %>" autocomplete="name" aria-required="true" class="w-full min-h-[44px] rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 outline-none transition focus:border-[#39B54A] focus:bg-white focus:ring-4 focus:ring-[#39B54A]/15" />
          <p class="mt-1 hidden text-xs text-red-600" data-field-error role="alert"></p>
        </div>
        <div data-warranty-field="customerPhone">
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="wa_phone">Số điện thoại <span class="text-red-500" aria-hidden="true">*</span></label>
          <input type="tel" name="customerPhone" id="wa_phone" value="<%= formValues.customerPhone || '' %>" autocomplete="tel" inputmode="tel" aria-required="true" class="w-full min-h-[44px] rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 outline-none transition focus:border-[#39B54A] focus:bg-white focus:ring-4 focus:ring-[#39B54A]/15" placeholder="Số dùng liên hệ (10 số, bắt đầu 0)" />
          <p class="mt-1 hidden text-xs text-red-600" data-field-error role="alert"></p>
        </div>
        <div class="lg:col-span-2">
          <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="wa_addr">Địa chỉ</label>
          <textarea name="customerAddress" id="wa_addr" rows="3" class="w-full min-h-[5.5rem] rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 text-sm outline-none transition focus:border-[#39B54A] focus:bg-white focus:ring-4 focus:ring-[#39B54A]/15" placeholder="Tùy chọn — hỗ trợ xác minh"><%= formValues.customerAddress || '' %></textarea>
        </div>
        <div class="lg:col-span-2 pt-1">
          <button type="submit" class="w-full min-h-[48px] rounded-xl bg-[#39B54A] py-3.5 text-sm font-semibold text-white shadow-lg shadow-[#39B54A]/30 transition hover:bg-[#2fa043] focus:outline-none focus:ring-4 focus:ring-[#39B54A]/35 active:scale-[0.99]">
            Gửi yêu cầu kích hoạt
          </button>
        </div>
      </div>
    </form>
    <script type="application/json" id="warranty-page-data"><%- JSON.stringify({
      serverFormError: (typeof formError !== 'undefined' && formError && !(typeof justSubmitted !== 'undefined' && justSubmitted)) ? String(formError) : null
    }) %></script>
  <% } %>

  <% var guidePts = typeof serialGuideProductTypes !== 'undefined' && serialGuideProductTypes ? serialGuideProductTypes : []; %>
  <% if (guidePts.length) { %>
    <section aria-labelledby="serial-guide-heading" class="mt-10 border-t border-slate-200/90 pt-10">
      <h2 id="serial-guide-heading" class="text-2xl font-extrabold leading-tight tracking-tight text-slate-900 sm:text-3xl lg:text-4xl">
        HƯỚNG DẪN TÌM SỐ SERIAL CỦA SẢN PHẨM
      </h2>
      <p class="mt-3 max-w-3xl text-base text-slate-600 sm:text-lg">
        Chạm hoặc nhấn vào ảnh từng loại để <strong class="text-slate-800">lật xem mặt sau</strong> — vị trí tem và số serial thường được minh họa rõ ràng.
      </p>
      <div class="mt-8">
        <%- include('../partials/warranty-product-types-grid', { productTypes: guidePts, showcaseVariant: 'serial-guide' }) %>
      </div>
    </section>
  <% } %>
</div>
