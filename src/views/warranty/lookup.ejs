<% var KIND_VI = { sale: 'Bán / xuất', activation: 'Kích hoạt bảo hành', admin: 'Ghi nhận' }; %>
<% var LP = typeof lookupPage !== 'undefined' && lookupPage ? lookupPage : {}; %>
<div class="mx-auto max-w-6xl px-4 sm:px-6">
  <div class="relative overflow-hidden rounded-2xl border border-[#39B54A]/25 bg-gradient-to-br from-[#39B54A] via-[#34a844] to-[#2d8f3e] px-5 py-8 text-white shadow-xl shadow-[#39B54A]/25 sm:px-8 sm:py-10">
    <div class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-white/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-8 left-1/4 h-32 w-64 rounded-full bg-teal-400/20 blur-2xl"></div>
    <div class="relative">
      <p class="mb-2 inline-flex rounded-full bg-white/15 px-3 py-0.5 text-xs font-semibold uppercase tracking-wider text-white/90 ring-1 ring-white/20"><%= LP.heroBadge || 'ToppiLife' %></p>
      <h1 class="text-2xl font-extrabold leading-tight tracking-tight sm:text-3xl lg:text-4xl"><%= LP.heroTitle || 'KIỂM TRA THỜI HẠN BẢO HÀNH ĐIỆN TỬ' %></h1>
      <div class="lookup-hero-intro mt-3 max-w-2xl text-sm leading-relaxed text-white/95 sm:text-base [&_a]:font-semibold [&_a]:text-white [&_a]:underline [&_a]:decoration-white/40 [&_a]:underline-offset-2">
        <%- LP.heroIntroHtml %>
      </div>
      <div class="lookup-hero-extra mt-3 max-w-2xl text-sm text-white/90 [&_a]:font-semibold [&_a]:text-white [&_a]:underline [&_a]:decoration-white/40 [&_a]:underline-offset-2 [&_a]:transition [&_a]:hover:decoration-white">
        <%- LP.heroExtraHtml %>
      </div>
    </div>
  </div>
</div>

<section class="mx-auto mt-10 max-w-6xl px-4 sm:px-6">
  <div class="rounded-2xl border border-slate-200/90 bg-white p-5 shadow-xl shadow-slate-900/5 ring-1 ring-slate-900/5 sm:p-8">
    <div class="mb-6 flex flex-col gap-1 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-lg font-bold tracking-tight text-slate-900 sm:text-xl"><%= LP.formCardTitle || 'Tra cứu' %></h2>
        <p class="text-sm text-slate-500"><%= LP.formCardSubtitle || '' %></p>
      </div>
    </div>
    <% if (typeof rateLimited !== 'undefined' && rateLimited) { %>
      <div class="mb-6 flex gap-3 rounded-xl border border-amber-200/80 bg-amber-50 px-4 py-3 text-sm text-amber-950" role="alert">
        <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-amber-200 text-amber-900 text-xs font-bold">!</span>
        <p>Bạn đã tra cứu quá nhiều lần trong khoảng thời gian ngắn. Vui lòng đợi vài phút rồi thử lại.</p>
      </div>
    <% } %>
    <form method="get" action="/bao-hanh/tra-cuu" data-warranty-form="lookup" class="grid grid-cols-1 gap-4 sm:grid-cols-12 sm:items-end">
      <div class="sm:col-span-10" data-warranty-field="q">
        <label class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500" for="wl_q"><%= LP.formFieldLabel || 'Số điện thoại hoặc serial / mã tem' %></label>
        <input
          type="text"
          name="q"
          id="wl_q"
          value="<%= typeof query !== 'undefined' && query.q != null ? query.q : '' %>"
          placeholder="<%= LP.formPlaceholder || 'VD: 0859123456 hoặc mã trên tem' %>"
          autocomplete="off"
          class="w-full rounded-xl border border-slate-200 bg-slate-50/50 px-4 py-3 font-mono text-sm text-slate-900 shadow-inner shadow-slate-900/5 outline-none transition placeholder:text-slate-400 focus:border-[#39B54A] focus:bg-white focus:ring-4 focus:ring-[#39B54A]/15"
        />
        <p class="mt-1 hidden text-xs text-red-600" data-field-error role="alert"></p>
      </div>
      <div class="sm:col-span-2">
        <button
          type="submit"
          class="w-full rounded-xl bg-white px-4 py-3 text-sm font-semibold text-[#39B54A] shadow-lg shadow-black/10 transition hover:bg-white/95 focus:outline-none focus:ring-4 focus:ring-white/40 active:scale-[0.98]"
        >
          <%= LP.formButtonLabel || 'Tra cứu' %>
        </button>
      </div>
    </form>
    <div class="lookup-form-footnote mt-4 text-xs leading-relaxed text-slate-500 [&_a]:font-semibold [&_a]:text-[#39B54A] [&_a]:underline">
      <%- LP.formFootnoteHtml %>
    </div>
  </div>
</section>

<% if (searched) { %>
<section class="mx-auto mt-12 max-w-6xl px-4 pb-8 sm:px-6">
  <h2 class="mb-6 text-lg font-bold tracking-tight text-slate-900 sm:text-xl">Kết quả</h2>
  <% if (!results || !results.length) { %>
    <div class="flex gap-4 rounded-2xl border border-slate-200 bg-slate-50/80 px-5 py-6 text-slate-700">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-200/80 text-slate-600">
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      </div>
      <div>
        <p class="font-semibold text-slate-900">Không tìm thấy thiết bị</p>
        <p class="mt-1 text-sm text-slate-600">Kiểm tra lại serial hoặc số điện thoại đã dùng khi đăng ký bảo hành.</p>
      </div>
    </div>
  <% } else { %>
    <% results.forEach(function (row) { %>
      <article class="mb-6 overflow-hidden rounded-2xl border border-slate-200/90 bg-white shadow-lg shadow-slate-900/5 ring-1 ring-slate-900/5 last:mb-0">
        <div class="border-b border-slate-100 bg-gradient-to-r from-slate-50/80 to-white px-5 py-4 sm:px-6">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <p class="text-xs font-medium uppercase tracking-wide text-slate-500">Sản phẩm</p>
              <p class="mt-0.5 text-lg font-semibold text-slate-900">
                <%= row.productTypeName || '—' %>
                <% if (row.productTypeCode) { %>
                  <span class="ml-1 font-mono text-sm font-normal text-slate-500">(<%= row.productTypeCode %>)</span>
                <% } %>
              </p>
            </div>
            <div class="rounded-lg bg-slate-100 px-3 py-1.5 font-mono text-sm text-slate-800 ring-1 ring-slate-200/80">
              <%= row.serialNumber || '—' %>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-1 gap-4 px-5 py-5 sm:grid-cols-3 sm:px-6">
          <div class="rounded-xl bg-slate-50/90 p-4 ring-1 ring-slate-100">
            <p class="text-xs font-medium text-slate-500">Khách hàng</p>
            <p class="mt-1 font-semibold text-slate-900"><%= row.customerName %></p>
          </div>
          <div class="rounded-xl bg-slate-50/90 p-4 ring-1 ring-slate-100">
            <p class="text-xs font-medium text-slate-500">SĐT (đã ẩn một phần)</p>
            <p class="mt-1 font-mono text-slate-800"><%= row.customerPhoneMasked %></p>
          </div>
          <div class="rounded-xl border border-[#39B54A]/25 bg-[#39B54A]/10 p-4 ring-1 ring-[#39B54A]/15">
            <p class="text-xs font-medium text-[#2d8f3e]">Hạn bảo hành (ước tính)</p>
            <p class="mt-1 text-lg font-bold text-[#267a32]">
              <% var wd = row.warrantyEndDate ? new Date(row.warrantyEndDate) : null; %>
              <%= wd && !isNaN(wd.getTime()) ? formatViDateOnly(wd) : '—' %>
            </p>
          </div>
        </div>
        <div class="border-t border-slate-100 bg-slate-50/40 px-5 py-5 sm:px-6">
          <h3 class="mb-4 flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-slate-700">
            <span class="h-px flex-1 bg-slate-200"></span>
            Nhật ký (hiển thị cho khách)
            <span class="h-px flex-1 bg-slate-200"></span>
          </h3>
          <% if (!row.deviceLogs || !row.deviceLogs.length) { %>
            <p class="text-sm text-slate-500">Chưa có mục nhật ký công khai.</p>
          <% } else { %>
            <ul class="relative ml-1.5 list-none space-y-0 border-l-2 border-slate-200 pl-6">
              <% row.deviceLogs.forEach(function (log) { %>
                <% var d = log.at ? new Date(log.at) : null; %>
                <% var ds = d && !isNaN(d.getTime()) ? formatViDateOnly(d) : '—'; %>
                <li class="relative pb-8 last:pb-0">
                  <% if (log.kind === 'sale') { %>
                    <span class="absolute -left-[1.4rem] top-1.5 flex h-3.5 w-3.5 items-center justify-center rounded-full bg-[#39B54A] ring-4 ring-white" aria-hidden="true"></span>
                  <% } else if (log.kind === 'activation') { %>
                    <span class="absolute -left-[1.4rem] top-1.5 flex h-3.5 w-3.5 items-center justify-center rounded-full bg-blue-500 ring-4 ring-white" aria-hidden="true"></span>
                  <% } else { %>
                    <span class="absolute -left-[1.4rem] top-1.5 flex h-3.5 w-3.5 items-center justify-center rounded-full bg-violet-500 ring-4 ring-white" aria-hidden="true"></span>
                  <% } %>
                  <div class="rounded-xl border border-slate-100 bg-white p-4 shadow-sm ring-1 ring-slate-900/5">
                    <div class="flex flex-wrap items-center gap-2 gap-y-1">
                      <time class="text-xs font-medium text-slate-500" datetime="<%= log.at ? new Date(log.at).toISOString() : '' %>"><%= ds %></time>
                      <% if (log.kind === 'sale') { %>
                        <span class="rounded-md bg-[#39B54A]/15 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-[#267a32]"><%= KIND_VI[log.kind] || log.kind %></span>
                      <% } else if (log.kind === 'activation') { %>
                        <span class="rounded-md bg-blue-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-blue-800"><%= KIND_VI[log.kind] || log.kind %></span>
                      <% } else { %>
                        <span class="rounded-md bg-violet-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-violet-800"><%= KIND_VI[log.kind] || log.kind %></span>
                      <% } %>
                    </div>
                    <p class="mt-2 whitespace-pre-wrap text-sm leading-relaxed text-slate-700"><%= log.message %></p>
                  </div>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      </article>
    <% }); %>
  <% } %>
</section>
<% } %>

<script type="application/json" id="warranty-page-data"><%- JSON.stringify({
  rateLimited: typeof rateLimited !== 'undefined' && !!rateLimited,
  rateLimitedMessage: 'Bạn đã tra cứu quá nhiều lần trong thời gian ngắn. Vui lòng đợi rồi thử lại.',
  notifyNoResults: typeof notifyNoResults !== 'undefined' && !!notifyNoResults,
  notifyNoResultsMessage: 'Không tìm thấy thiết bị — kiểm tra lại SĐT hoặc serial đã đăng ký.'
}) %></script>
