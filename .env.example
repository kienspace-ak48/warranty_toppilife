HTTP_PORT=3000

# Đăng nhập admin (/auth/login → cookie httpOnly + JWT)
# Bắt buộc production: chuỗi dài, ngẫu nhiên (≥ 16 ký tự).
JWT_SECRET=
# Ví dụ: 8h, 15m, 7d (đồng bộ maxAge cookie)
JWT_EXPIRES_IN=8h
# Chỉ dev: GET /auth/register tạo user mẫu — KHÔNG bật trên production
# AUTH_ALLOW_BOOTSTRAP_REGISTER=true

# MongoDB — chọn một trong hai cách (xem src/configs/dbConnection.js):
# A) Chuỗi đầy đủ: Atlas (mongodb+srv://...) hoặc local (mongodb://127.0.0.1:27017/ten_db)
# MONGO_URI=
# B) Không đặt MONGO_URI → dùng các biến DB_* bên dưới
DB_HOST=127.0.0.1
DB_PORT=27017
DB_NAME=warranty_toppilife
# DB_USER=
# DB_PASSWORD=
# DB_AUTH_SOURCE=admin

# CORS (tuỳ chọn)
# CORS_ORIGINS=http://localhost:4200

# Tra cứu công khai (/bao-hanh/tra-cuu có phone hoặc serial): giới hạn theo IP
# WARRANTY_LOOKUP_RATE_MAX=60
# WARRANTY_LOOKUP_RATE_WINDOW_MS=900000
# Đặt =1 khi chạy sau reverse proxy (nginx) để lấy đúng IP khách
# TRUST_PROXY=1

# URL gốc site (QR kích hoạt bảo hành — tránh host/port sai khi deploy).
# Nên đặt trên production. Dev có thể trùng cổng app, ví dụ:
# PUBLIC_BASE_URL=http://localhost:8084
# PUBLIC_BASE_URL=https://your-domain.com
# Không đặt → dùng protocol + Host từ request (tiện thử nhanh).
# PUBLIC_BASE_URL=

# POST /bao-hanh/kich-hoat — giới hạn theo IP
# WARRANTY_ACTIVATION_RATE_MAX=20
# WARRANTY_ACTIVATION_RATE_WINDOW_MS=900000

# Khi chưa có loại SP “tra cứu công khai” trong DB — hiển thị 2 thẻ demo ở khối hướng dẫn serial (trang chủ + kích hoạt). Production: không bật.
# WARRANTY_MOCK_SERIAL_GUIDE=1
